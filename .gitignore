# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local
.env

# vercel
.vercel

# cloudflare / wrangler
.wrangler/
.dev.vars
.dev.vars.*
.open-next/

# typescript
*.tsbuildinfo
next-env.d.ts

# icon generated file
src/assets/iconify-icons/generated-icons.js
src/assets/iconify-icons/generated-icons.css

# prisma-client generator output (regenerated on `npm install` via postinstall)
src/generated/

# next-pwa service worker output (regenerated on `next build`)
public/sw.js
public/workbox-*.js

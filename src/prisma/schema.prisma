// Schema untuk Supabase Postgres (diakses via pg + @prisma/adapter-pg
// di Cloudflare Workers). Gunakan URL Supavisor Session mode (port 5432)
// untuk `DATABASE_URL`; Transaction mode (port 6543) akan memecah
// `prisma.$transaction([...])` di route restore.

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Opsional: koneksi direct Supabase untuk migration
}

generator client {
  // The new `prisma-client` generator (Prisma 6+) emits a pure-ESM client
  // that omits the native libssl/library-engine probe which calls
  // fs.readdir at runtime and explodes on Cloudflare Workers' unenv-based
  // Node compat shim. `prisma-client-js` (the legacy default) still
  // bundles that probe even when a driver adapter is used.
  provider     = "prisma-client"
  output       = "../generated/prisma"
  runtime      = "cloudflare"
  moduleFormat = "esm"
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// TABUNGAN KELUARGA MODELS
// ==========================================

model FamilyMember {
  id           String        @id @default(cuid())
  name         String
  role         String
  avatar       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model SavingsCategory {
  id            String        @id @default(cuid())
  name          String
  description   String?
  icon          String?
  color         String?
  targetAmount  Float?

  storageTypeId String?
  storageType   StorageType?  @relation(fields: [storageTypeId], references: [id], onDelete: SetNull)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]
}

model ExpenseCategory {
  id            String        @id @default(cuid())
  name          String
  description   String?
  icon          String?
  color         String?
  budgetLimit   Float?

  storageTypeId String?
  storageType   StorageType?  @relation(fields: [storageTypeId], references: [id], onDelete: SetNull)

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  transactions  Transaction[]
}

model StorageType {
  id                String            @id @default(cuid())
  name              String
  description       String?
  icon              String?
  color             String?
  accountNumber     String?
  balance           Float             @default(0)
  initialBalance    Float             @default(0)

  // Gold storage fields
  isGold            Boolean           @default(false)
  goldWeight        Float?            // Weight in grams
  initialGoldWeight Float?            // Opening gold weight in grams

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  savingsCategories SavingsCategory[]
  expenseCategories ExpenseCategory[]
  transactionsFrom  Transaction[]     @relation("TransactionFrom")
  transactionsTo    Transaction[]     @relation("TransactionTo")
}

model Transaction {
  id                String           @id @default(cuid())
  type              String
  amount            Float
  description       String?
  date              DateTime         @default(now())

  familyMemberId    String?
  familyMember      FamilyMember?    @relation(fields: [familyMemberId], references: [id], onDelete: SetNull)

  savingsCategoryId String?
  savingsCategory   SavingsCategory? @relation(fields: [savingsCategoryId], references: [id], onDelete: SetNull)

  expenseCategoryId String?
  expenseCategory   ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id], onDelete: SetNull)

  fromStorageTypeId String?
  fromStorageType   StorageType?     @relation("TransactionFrom", fields: [fromStorageTypeId], references: [id], onDelete: SetNull)

  toStorageTypeId   String?
  toStorageType     StorageType?     @relation("TransactionTo", fields: [toStorageTypeId], references: [id], onDelete: SetNull)

  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Indexes that match the actual access patterns in the API:
  //   - GET /api/apps/tabungan/transactions sorts by `(date desc, createdAt desc)`
  //     and optionally filters by `type`, `familyMemberId`, and date range.
  //   - GET /api/apps/tabungan/stats filters by date range only.
  //   - storage-type filters use `OR` on from/to ids — separate single-column
  //     indexes let Postgres bitmap-OR them efficiently.
  // Without these, every list query is a sequential scan + in-memory sort,
  // which is the single biggest source of "get transaksi" latency.
  @@index([date(sort: Desc), createdAt(sort: Desc)])
  @@index([type, date(sort: Desc)])
  @@index([familyMemberId])
  @@index([fromStorageTypeId])
  @@index([toStorageTypeId])
  @@index([savingsCategoryId])
  @@index([expenseCategoryId])
}
